# Copy to .env (local) OR set these in Vercel Environment Variables (recommended)

# --- Public site URL (used for canonical URLs, OG tags, sitemap, robots) ---
VITE_SITE_URL=https://www.eminenceluxuryhair.com

# --- Analytics / pixels (optional; only load after cookie consent) ---
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Meta Pixel ID (optional)
VITE_META_PIXEL_ID=

# TikTok Pixel ID (optional)
VITE_TIKTOK_PIXEL_ID=

# --- Supabase (client — exposed to the browser via Vite) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase (server — NEVER expose to the browser) ---
# SUPABASE_URL is the server-side env var used by API routes and serverless functions.
# Set it to the same Project URL as VITE_SUPABASE_URL.
# Prefer SUPABASE_URL over VITE_SUPABASE_URL in server code.
SUPABASE_URL=

# Service role key is SERVER-ONLY. Do NOT expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=

# (Optional) Private Storage bucket for Custom Atelier reference uploads
# Recommended: create a private bucket named "atelier-uploads"
SUPABASE_ATELIER_BUCKET=atelier-uploads

# --- Stripe (server) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (server) ---
RESEND_API_KEY=

# --- Twilio Verify (server) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Admin access (SERVER-ONLY) ---
# Comma-separated allowlist of admin emails for /admin/* API routes.
# This is enforced server-side. It is NEVER exposed to the browser.
# Example: ADMIN_EMAILS=founder@eminenceluxuryhair.com,ops@eminenceluxuryhair.com
ADMIN_EMAILS=

# Client-side admin UI guard (UX convenience only — NOT a security boundary).
# Must match ADMIN_EMAILS so the /admin/partners route renders for the right users.
# The VITE_ prefix makes this value visible in browser bundles — do NOT treat it
# as a secret. Real authorization is enforced server-side via ADMIN_EMAILS.
VITE_ADMIN_EMAILS=

# --- Live chat (optional) ---
# Crisp Website ID (enables chat widget)
VITE_CRISP_WEBSITE_ID=
# Set to "partner" to only show chat for approved partners
VITE_CRISP_VISIBILITY=all
